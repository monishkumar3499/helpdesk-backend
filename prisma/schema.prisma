generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String   @id @default(nanoid(10))
  name            String
  email           String   @unique
  password        String
  role            Role
  isActive        Boolean  @default(true)
  
  // Profile Information
  phoneNumber     String?
  employeeId      String?   @unique
  jobTitle        String?
  department      String?   // Employee's actual department (e.g., Marketing, Sales)
  profileImage    String?
  joiningDate     DateTime? @default(now())

  // Management Info
  managerId       String?
  manager         User?     @relation("UserManager", fields: [managerId], references: [id])
  reportees       User[]    @relation("UserManager")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assetsAssigned  Asset[]  @relation("AssetOwner")
  ticketsAssigned Ticket[] @relation("TicketAssignee")
  ticketsCreated  Ticket[] @relation("TicketCreator")
  comments        TicketComment[]

  @@index([email])
  @@index([role])
  @@index([managerId])
}

model Ticket {
  id           String         @id @default(nanoid(10))
  ticketNumber Int            @default(autoincrement())

  title        String
  summary      String         // Short summary/heading
  description  String?        // Detailed breakdown
  imageUrl     String?

  status       TicketStatus   @default(OPEN)
  priority     TicketPriority @default(LOW)
  department   Department     // HR or IT (assigned service)

  // Specific Request Details
  requestType         RequestType?
  assetDescription    String?
  serviceDescription  String?
  
  // Resolution Info
  resolvedAt   DateTime?
  closedAt     DateTime?

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  createdById  String
  assignedToId String?

  createdBy    User            @relation("TicketCreator", fields: [createdById], references: [id], onDelete: Cascade)
  assignedTo   User?           @relation("TicketAssignee", fields: [assignedToId], references: [id])
  comments     TicketComment[]

  @@index([status])
  @@index([priority])
  @@index([department])
  @@index([createdById])
  @@index([assignedToId])
}

model TicketComment {
  id        String   @id @default(nanoid(10))
  content   String
  createdAt DateTime @default(now())
  
  ticketId  String
  userId    String
  
  ticket    Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([ticketId])
  @@index([userId])
}

model Asset {
  id           String      @id @default(uuid())
  serialNumber String      @unique
  assetName    String
  assetType    String
  description  String?

  assetStatus  AssetStatus @default(AVAILABLE)

  assignedToId String?
  assignedDate DateTime?

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  assignedTo   User? @relation("AssetOwner", fields: [assignedToId], references: [id])

  @@index([assetStatus])
  @@index([assetType])
  @@index([assignedToId])
}

enum Role {
  EMPLOYEE
  HR
  IT_SUPPORT
  IT_ADMIN
  ADMIN
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Department {
  HR
  IT
  FINANCE
  MARKETING
  OPERATIONS
  FACILITIES
}

enum RequestType {
  ASSET
  SERVICE
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  RETIRED
}