// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}


datasource db {
  provider = "postgresql"
}

enum Role {
  EMPLOYEE
  HR
  IT
  ADMIN
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum TicketPriority {
  CRITICAL
  HIGH
  LOW
}

enum Department {
  HR
  IT
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  RETIRED
}

model User {
  id         Int       @id @default(autoincrement())
  name       String
  email      String    @unique
  password   String
  role       Role
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  ticketsCreated  Ticket[] @relation("TicketCreator")
  ticketsAssigned Ticket[] @relation("TicketAssignee")
  assetsAssigned  Asset[]  @relation("AssetOwner")

  @@index([email])
  @@index([role])
}

model Ticket {
  id            Int           @id @default(autoincrement())   // ← internal PK, fast
  code          String        @unique @db.VarChar(16)        // ← human friendly: TICK-0000123
  title         String
  summary       String
  imageUrl      String?
  status        TicketStatus  @default(OPEN)
  priority      TicketPriority @default(LOW)
  department    Department
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  createdById   Int
  createdBy     User          @relation("TicketCreator", fields: [createdById], references: [id])

  assignedToId  Int?
  assignedTo    User?         @relation("TicketAssignee", fields: [assignedToId], references: [id])

  @@index([status])
  @@index([priority])
  @@index([department])
  @@index([createdById])
  @@index([assignedToId])
}

model Asset {
  id            Int           @id @default(autoincrement())   // ← internal PK
  code          String        @unique @db.VarChar(16)        // ← AST-0000456
  serialNumber  String        @unique                       // keep if needed for physical label
  assetName     String
  assetType     String
  assetStatus   AssetStatus   @default(AVAILABLE)
  assignedToId  Int?
  assignedTo    User?         @relation("AssetOwner", fields: [assignedToId], references: [id])
  assignedDate  DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([assetStatus])
  @@index([assetType])
  @@index([assignedToId])
}
