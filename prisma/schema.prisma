// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}



//////////////////////
// ENUMS
//////////////////////

enum Role {
  EMPLOYEE
  HR
  IT_SUPPORT
  IT_ADMIN // <-- FIXED TYPO HERE
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum TicketPriority {
  CRITICAL
  HIGH
  LOW
}

enum Department {
  HR
  IT
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  RETIRED
}

enum AssetType {
  NETWORK
  SOFTWARE
  HARDWARE
}

//////////////////////
// USERS (AUTH)
//////////////////////

model User {
  id        String   @id @default(nanoid(10))
  name      String
  email     String   @unique
  password  String
  role      Role
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  ticketsCreated  Ticket[] @relation("TicketCreator")
  ticketsAssigned Ticket[] @relation("TicketAssignee")
  assetsAssigned  Asset[]  @relation("AssetOwner")

  @@index([email])
  @@index([role])
  assetAssignments AssetAssignment[] @relation("AssignedByAction")
  assetsReceived AssetAssignment[] @relation("AssignedToAction")
}

//////////////////////
// TICKETS
//////////////////////

model Ticket {
  id          String         @id @default(nanoid(10))
  title       String
  summary     String
  imageUrl    String?

  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(LOW)
  department  Department

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 🔹 creator
  createdById String
  createdBy   User @relation("TicketCreator", fields: [createdById], references: [id])

  // 🔹 assignee (HR or IT)
  assignedToId String?
  assignedTo   User? @relation("TicketAssignee", fields: [assignedToId], references: [id])

  // Optional one-to-one detail for asset request/problem tickets
  assetRequest AssetRequest?

  @@index([status])
  @@index([priority])
  @@index([department])
  @@index([createdById])
  @@index([assignedToId])
}

//////////////////////
// ASSET REQUESTS (Ticket-linked Details)
//////////////////////

model AssetRequest {
  id                  String   @id @default(uuid())

  // One-to-one mapping with a ticket
  ticketId            String   @unique
  ticket              Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  // Optional requested asset reference and free-text descriptors
  assetId             String?
  asset               Asset?   @relation(fields: [assetId], references: [id])
  assetCategory       String?
  assetClassification String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([assetId])
}

//////////////////////
// ASSETS (MINIMAL)
//////////////////////

model Asset {
  id            String      @id @default(uuid())
  serialNumber  String      @unique // human readable like AST-001
  assetName     String
  assetType     AssetType
  assetStatus   AssetStatus @default(AVAILABLE)

  assignedToId  String?
  assignedTo    User? @relation("AssetOwner", fields: [assignedToId], references: [id])

  assignedDate  DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([assetStatus])
  @@index([assetType])
  @@index([assignedToId])
  assetAssignments AssetAssignment[]
  assetRequests    AssetRequest[]
}

//////////////////////
// ASSET ASSIGNMENTS (History/Logs)
//////////////////////

model AssetAssignment {
  id           String   @id @default(uuid())
  
  // The IT_SUPPORT or IT_ADMIN Member who performed the assignment
  assignedById String
  assignedBy   User     @relation("AssignedByAction", fields: [assignedById], references: [id])

  // The Employee receiving the asset
  assignedToId String
  assignedTo   User     @relation("AssignedToAction", fields: [assignedToId], references: [id])

  // The specific Asset being moved
  assetId      String
  asset        Asset    @relation(fields: [assetId], references: [id])

  assignedAt   DateTime @default(now())

  @@index([assignedById])
  @@index([assignedToId])
  @@index([assetId])
}